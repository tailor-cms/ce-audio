{
  "name": "@tailor-cms/ce-audio-manifest",
  "description": "Tailor CMS audio element manifest",
  "author": "Studion <info@gostudion.com> (https://github.com/tailor-cms)",
  "type": "module",
  "version": "0.1.1",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm nuke:dist && tsdown",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "nuke": "pnpm dlx del-cli dist node_modules",
    "nuke:dist": "pnpm dlx del-cli dist",
    "prepublish": "pnpm build"
  },
  "dependencies": {
    "@tailor-cms/cek-common": "^2.0.0-beta.11"
  },
  "devDependencies": {
    "@tailor-cms/eslint-config": "^2.0.0-beta.11",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "tsdown": {
    "target": "node24",
    "format": ["cjs", "esm"]
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  }
}
